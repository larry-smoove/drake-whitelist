# Local front-end URL (GitHub Pages can use a deployed Vercel function URL)
VITE_SUBMIT_URL=http://localhost:3000/api/submit-whitelist

# Vercel serverless function env vars (do not commit your real values)
# These go into Vercel project secrets, not the GitHub Pages site.
AIRTABLE_API_KEY=your_airtable_api_key
AIRTABLE_BASE=your_airtable_base_id
AIRTABLE_TABLE=Whitelist
